<!-- BEGIN region:nextstep -->
<div class="cta-card">
  <p class="pending">2.0 KB still in Trash</p>
  <code class="empty-cmd">osascript -e 'tell application "Finder" to empty the trash'</code>
  <p class="auto-note">Running the command above will trigger a Finder confirmation dialog. macOS auto-empties 30 days after items enter the Trash if enabled.</p>
</div>
