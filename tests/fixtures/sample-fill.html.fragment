<!--
  Concatenated region replacements used by dry-e2e.sh to simulate the
  agent's Stage 6 fill-in. Each block below is a complete replacement
  for one paired-marker region. The harness splices them into the two
  report templates.

  The first four regions go into report.html (hero / impact / nextstep
  / share); the next four go into details.html (distribution / actions
  / observations / runmeta).

  Content is intentionally redaction-safe (category names + made-up
  sizes, no paths, no usernames).

  Companion fixture: tests/fixtures/sample-classified.json contains
  sentinel paths "__WILL_BE_REPLACED_AT_RUNTIME__/..." that dry-e2e.sh
  rewrites at runtime to point at a tempdir created by mktemp. JSON
  does not allow comments, hence this note here instead.
-->

<!-- BEGIN region:hero -->
<div class="hero-body">
  <p class="hero-headline">12.3 GB<span class="unit">freed</span></p>
  <p class="hero-caption">Clean run on <strong>MacBook Pro</strong>, macOS 14.5, in 2m 14s.</p>
  <span class="pending-note">+ 2.0 KB pending in trash</span>
  <div class="meta-bar">
    <span class="chip mode">Deep Clean</span>
    <span class="chip"><span class="chip-label">device</span>MacBook Pro</span>
    <span class="chip"><span class="chip-label">os</span>macOS 14.5</span>
    <span class="chip"><span class="chip-label">duration</span>2m 14s</span>
  </div>
  <div class="risk-strip">
    <span class="risk-chip l1"><span class="glyph"></span>L1 12.0 KB <span class="count">· 2 items</span></span>
    <span class="risk-chip l2"><span class="glyph"></span>L2 2.0 KB <span class="count">· 1 item</span></span>
    <span class="risk-chip l3"><span class="glyph"></span>L3 50.0 GB <span class="count">· 1 deferred</span></span>
    <span class="risk-chip l4"><span class="glyph"></span>L4 0 B <span class="count">· 0 items</span></span>
  </div>
</div>
<!-- END region:hero -->

<!-- BEGIN region:impact -->
<div class="impact-grid">
  <div class="impact-card">
    <div class="title">Disk before vs. after</div>
    <div class="water-bar">
      <span class="used-before" style="width:60%"></span>
      <span class="freed-delta" style="width:2%"></span>
      <span class="free-after" style="width:38%"></span>
    </div>
    <div class="water-legend">
      <span><b>Before</b>240.0 GB free</span>
      <span><b>After</b>252.3 GB free</span>
    </div>
  </div>
  <div class="impact-card">
    <div class="title">Freed this run, by category</div>
    <div class="stack-bar">
      <span class="seg-1" style="flex-basis:67%" title="Old installers: 8 KB"></span>
      <span class="seg-2" style="flex-basis:33%" title="Developer caches: 4 KB"></span>
    </div>
    <ul class="stack-legend">
      <li><span class="swatch" style="background:var(--accent)"></span><span class="name">Old installers</span><span class="bytes">8 KB</span></li>
      <li><span class="swatch" style="background:#34d399"></span><span class="name">Developer caches</span><span class="bytes">4 KB</span></li>
    </ul>
  </div>
</div>
<!-- END region:impact -->

<!-- BEGIN region:nextstep -->
<div class="cta-card">
  <p class="pending">2.0 KB still in Trash</p>
  <code class="empty-cmd">osascript -e 'tell application "Finder" to empty the trash'</code>
  <p class="auto-note">Running the command above will trigger a Finder confirmation dialog &mdash; click 'Empty Trash' there to actually clear it. macOS auto-empties 30 days after items enter the Trash if you've enabled Finder &rarr; Settings &rarr; Advanced &rarr; 'Remove items from the Trash after 30 days'.</p>
</div>
<!-- END region:nextstep -->

